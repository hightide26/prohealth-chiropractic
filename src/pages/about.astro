---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CtaBanner from '../components/CtaBanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Physician",
  "name": "Dr. James Yager",
  "jobTitle": "Doctor of Chiropractic",
  "worksFor": {
    "@type": "MedicalBusiness",
    "name": "ProHealth Chiropractic Wellness Centers",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "2502 N. Johns St., Suite B",
      "addressLocality": "Garden City",
      "addressRegion": "KS",
      "postalCode": "67846"
    }
  },
  "telephone": "+16202710243",
  "alumniOf": "Parker University",
  "url": "https://prohealthks.com/about"
};

const team = [
  { initials: 'JY', name: 'Jodi Yager', role: 'Diet & Wellness Coach', bio: 'Jodi leads the Yager Diet program and personally guides every patient through their weight management journey. She\'s known for her warmth, accountability, and genuine investment in every patient\'s success.' },
  { initials: 'AO', name: 'Andrea', role: 'Office Manager', bio: 'Andrea keeps the entire clinic running smoothly. She handles scheduling, insurance questions, and makes sure every patient feels welcome from the moment they walk in the door.' },
  { initials: 'AM', name: 'Amy', role: 'Pre-Adjustment Therapy', bio: 'Amy works with patients before their adjustment, using muscle therapy and e-stim to prepare the body for the best possible results from Dr. Yager\'s treatment.' },
  { initials: 'TF', name: 'Tonya', role: 'Front Desk', bio: 'Tonya is usually the first face you see. She\'s upbeat, organized, and ensures every patient feels cared for — whether it\'s their first visit or their hundredth.' },
];

const whyItems = [
  { icon: '🎯', title: 'Root Cause Focus', desc: 'Dr. Yager doesn\'t just treat symptoms — he finds out why you\'re hurting and corrects the source.' },
  { icon: '💻', title: 'ProAdjuster Technology', desc: 'Computer-guided, FDA-cleared instrument that diagnoses and adjusts with pinpoint precision — no cracking required.' },
  { icon: '👨‍👩‍👧‍👦', title: 'Family-Friendly Care', desc: 'We treat everyone from toddlers to great-grandparents. The ProAdjuster is gentle enough for any age.' },
  { icon: '⏰', title: 'Extended Hours', desc: 'Open until 5:30 PM so you can get care without disrupting your work schedule.' },
  { icon: '❤️', title: 'Personal Attention', desc: 'Dr. Yager personally sees every patient. You\'ll never be passed off to an assistant for your adjustment.' },
  { icon: '📍', title: 'Trusted in Garden City', desc: '25+ years serving Southwest Kansas, with 54 five-star Google reviews to show for it.' },
];
---

<Layout
  title="About Dr. James Yager | ProHealth Chiropractic Garden City KS"
  description="Meet Dr. James Yager and the team at ProHealth Chiropractic in Garden City, Kansas. 25+ years of gentle, effective chiropractic care using the ProAdjuster system."
  canonical="https://prohealthks.com/about"
  schema={schema}
  pageClass="page-about"
>
  <Nav slot="nav" activePage="About" />

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="container page-hero__inner">
      <div class="page-hero__content" data-gsap="fade-up">
        <div class="badge badge--blue">Our Story</div>
        <h1>Care You Can Feel.<br /><em>People You'll Trust.</em></h1>
        <p>ProHealth Chiropractic has been a cornerstone of Garden City healthcare since 1999. Dr. James Yager built this practice on one belief: that people deserve real answers and real relief — not just symptom management.</p>
      </div>
    </div>
  </section>

  <!-- DR. YAGER BIO -->
  <section class="section">
    <div class="container about__inner">
      <div class="about__visual" data-gsap="fade-right">
        <div class="about__img-wrap">
          <div class="about__img-placeholder">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>Dr. Yager Photo</span>
          </div>
        </div>
        <div class="about__credential">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Doctor of Chiropractic — Parker University, 1999
        </div>
      </div>
      <div class="about__content" data-gsap="fade-up">
        <div class="badge badge--blue">Your Chiropractor</div>
        <h2>Dr. James Yager, D.C.</h2>
        <p>Dr. Yager graduated from Parker University in Dallas, Texas in 1999 — one of the most respected chiropractic programs in the country. From the beginning, he was drawn to techniques that could help the widest range of patients, including those who'd been told chiropractic "wasn't for them."</p>
        <p>That's why the ProAdjuster became central to his practice. When patients who were afraid of manipulation, post-surgical patients, or seniors who'd never tried chiropractic came in and walked out with real relief — he knew he'd found something special.</p>
        <p>Over 25 years, Dr. Yager has built a reputation that speaks for itself: 54 five-star Google reviews, patients who drive from Liberal, Dodge City, and beyond, and a clinic that feels more like a family than a medical office.</p>
        <blockquote class="about__quote">
          "Life is too short to suffer and struggle needlessly. If you're in pain, come see us. Let's figure it out together."
          <cite>— Dr. James Yager</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- TEAM GRID -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header" data-gsap="fade-up">
        <div class="badge badge--blue">The Full Team</div>
        <h2>The People Behind Your Care</h2>
        <p>Great chiropractic isn't just about the doctor. It's about everyone who touches your experience — from the first phone call to the last visit.</p>
      </div>
      <div class="team-grid">
        {team.map((member, i) => (
          <div class="team-card" data-gsap="fade-up" data-delay={String(i * 0.1)}>
            <div class="team-card__avatar">{member.initials}</div>
            <h3>{member.name}</h3>
            <span class="team-card__role">{member.role}</span>
            <p>{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="section">
    <div class="container">
      <div class="section-header" data-gsap="fade-up">
        <div class="badge badge--blue">Why ProHealth</div>
        <h2>Why Garden City Chooses Us</h2>
        <p>There's no shortage of chiropractors in Kansas. Here's what makes ProHealth different.</p>
      </div>
      <div class="why-grid">
        {whyItems.map((item, i) => (
          <div class="why-card" data-gsap="fade-up" data-delay={String(i * 0.08)}>
            <div class="why-card__icon">{item.icon}</div>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INFO BANNER -->
  <section class="info-banner">
    <div class="container info-banner__inner">
      <div data-gsap="fade-up">
        <h2>Ready to Experience the ProHealth Difference?</h2>
        <p>New patients receive extra time with Dr. Yager so we can understand your full history and create a personalized care plan that actually works.</p>
      </div>
      <div class="info-banner__actions" data-gsap="fade-up">
        <a href="https://squareup.com/appointments/book/ejx1i5qse7fkql/LEEFEEKJTRBZY/start" target="_blank" class="btn btn--white btn--lg">Book Your First Visit</a>
        <a href="tel:6202710243" class="btn btn--outline-white btn--lg">Call (620) 271-0243</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
