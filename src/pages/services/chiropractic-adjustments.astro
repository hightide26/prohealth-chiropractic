---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import CtaBanner from '../../components/CtaBanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "Chiropractic Adjustments in Garden City, KS",
  "url": "https://prohealthks.com/services/chiropractic-adjustments",
  "description": "ProHealth Chiropractic offers gentle chiropractic adjustments in Garden City, KS using the ProAdjuster and manual techniques. Dr. Yager creates personalized care plans for lasting relief.",
  "about": {
    "@type": "MedicalTherapy",
    "name": "Chiropractic Adjustment",
    "description": "Spinal manipulation to restore joint motion, reduce nerve interference, and relieve pain"
  }
};

const techniques = [
  {
    name: 'ProAdjuster (Computer-Guided)',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    desc: 'Our primary technique. A 7th-generation, FDA-cleared instrument that uses piezoelectric sensor technology to objectively measure spinal motion and deliver precise, gentle oscillating adjustments. No cracking, no twisting — and results you can see in the computer readout.',
    best: 'All patients, especially those nervous about manual adjustment, seniors, children, post-surgical patients, acute injuries, and pregnant women.',
  },
  {
    name: 'Diversified Technique',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    desc: 'The most widely used manual chiropractic technique. Dr. Yager delivers a precise, high-velocity, low-amplitude thrust to a specific spinal joint to restore motion. This is the "traditional" chiropractic adjustment — the one that may produce the familiar audible pop (which is simply gas releasing from the joint, not bones cracking).',
    best: 'Patients who respond well to manual adjustment and prefer a hands-on approach.',
  },
  {
    name: 'Thompson Drop Table',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="8" width="18" height="10" rx="2"/><path d="M7 8V6a2 2 0 012-2h6a2 2 0 012 2v2"/><line x1="12" y1="12" x2="12" y2="16"/></svg>`,
    desc: 'Uses a specialized adjusting table with sections that drop slightly during the adjustment. This allows Dr. Yager to use less force while still achieving excellent joint mobilization — the table\'s motion assists the thrust. Gentler than Diversified and particularly effective for pelvic and lumbar conditions.',
    best: 'Patients with lower back and pelvic issues, or those who prefer less applied force.',
  },
  {
    name: 'Soft Tissue & E-Stim Therapy',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>`,
    desc: 'Before or alongside spinal adjustment, Amy (our pre-adjustment therapist) uses soft tissue work and electrical stimulation (e-stim) to relax tight muscles, reduce inflammation, and prepare the surrounding tissue for optimal adjustment results.',
    best: 'Most patients benefit from pre-adjustment therapy. It significantly improves adjustment outcomes.',
  },
];
---

<Layout
  title="Chiropractic Adjustments in Garden City, KS | ProHealth Chiropractic"
  description="Dr. James Yager offers chiropractic adjustments in Garden City, KS using the ProAdjuster and manual techniques. Personalized care for back pain, neck pain, and more. Call (620) 271-0243."
  canonical="https://prohealthks.com/services/chiropractic-adjustments"
  schema={schema}
  pageClass="page-service"
>
  <Nav slot="nav" />

  <!-- HERO -->
  <section class="page-hero">
    <div class="container page-hero__inner">
      <div class="page-hero__content" data-gsap="fade-up">
        <div class="badge badge--blue">Chiropractic Adjustments</div>
        <h1>Precise, Personalized<br /><em>Adjustments That Last</em></h1>
        <p>Not all chiropractic adjustments are the same. Dr. Yager uses a combination of computer-guided and manual techniques — tailored to your body, your history, and your goals — to deliver results that hold.</p>
        <div class="hero__actions" style="margin-top: 28px;">
          <a href="https://squareup.com/appointments/book/ejx1i5qse7fkql/LEEFEEKJTRBZY/start" target="_blank" class="btn btn--primary btn--lg">Book an Appointment</a>
          <a href="tel:6202710243" class="btn btn--outline btn--lg">Call (620) 271-0243</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <section class="section condition-page">
    <div class="container condition-page__inner">

      <div class="condition-page__content" data-gsap="fade-up">

        <h2>What Is a Chiropractic Adjustment?</h2>
        <p>A chiropractic adjustment — also called spinal manipulation — is a controlled, directed force applied to a spinal joint that has become restricted in movement or is positioned abnormally. The goal is simple: restore proper motion, relieve pressure on surrounding nerves and soft tissue, and allow the body's natural healing processes to work unimpeded.</p>
        <p>When a spinal joint loses its normal range of motion — due to injury, poor posture, repetitive stress, or accumulated wear — it creates a cascade of problems. Muscles tighten to protect the area. Nerves that pass through or near that joint get compressed or irritated. Pain signals fire. And over time, what started as a minor restriction becomes a chronic, limiting problem.</p>
        <p>A well-delivered chiropractic adjustment interrupts that cycle at the source.</p>

        <h2>The Goal Isn't the Pop — It's the Motion</h2>
        <p>Many people associate chiropractic adjustments with the audible pop or crack. That sound is simply the release of nitrogen gas from within the joint capsule — similar to cracking your knuckles. It's harmless, and it doesn't indicate whether the adjustment was effective.</p>
        <p>At ProHealth Chiropractic, we're focused on something more important: restoring proper joint motion and reducing nerve interference. Whether that happens with or without an audible pop — and whether it's achieved through the ProAdjuster's gentle oscillating impulses or through a manual thrust — what matters is that your spine is moving better and your nervous system is freer to do its job.</p>

        <h2>Dr. Yager's Approach: Personalized to You</h2>
        <p>No two patients are the same, and Dr. Yager doesn't treat them that way. Before any adjustment, he takes time to understand your full history — what you've tried before, what's worked, what hasn't, what you're most comfortable with. Then he uses the ProAdjuster to assess your spine objectively.</p>
        <p>Based on what the computer shows him and what he learns from talking with you, he selects the technique or combination of techniques that's right for your situation. Most patients are primarily treated with the ProAdjuster. Some benefit from a combination. And all patients receive pre-adjustment muscle work from Amy before Dr. Yager adjusts — because a well-prepared muscle releases faster and holds the correction longer.</p>

        <h2>Techniques We Use</h2>
        <div class="techniques-grid">
          {techniques.map(t => (
            <div class="technique-card">
              <div class="technique-card__icon" set:html={t.icon} />
              <div class="technique-card__body">
                <h3>{t.name}</h3>
                <p>{t.desc}</p>
                <p class="technique-card__best"><strong>Best for:</strong> {t.best}</p>
              </div>
            </div>
          ))}
        </div>

        <h2>What Chiropractic Adjustments Treat</h2>
        <p>Spinal adjustments address a wide range of conditions — not because chiropractors claim to cure everything, but because so many symptoms are driven by spinal dysfunction that creates nerve interference:</p>
        <ul>
          <li><strong>Back pain</strong> — the #1 reason people seek chiropractic care</li>
          <li><strong>Neck pain and stiffness</strong></li>
          <li><strong>Headaches and migraines</strong> — especially those originating from the upper cervical spine</li>
          <li><strong>Sciatica</strong> — radiating pain, numbness, or tingling down the leg</li>
          <li><strong>Disc injuries</strong> — bulging, herniated, or degenerative discs</li>
          <li><strong>Whiplash</strong> and other auto accident injuries</li>
          <li><strong>Sports injuries</strong> — sprains, strains, and joint dysfunction</li>
          <li><strong>Work injuries</strong> — lifting injuries, repetitive motion conditions</li>
          <li><strong>Shoulder, arm, and hand symptoms</strong> from cervical nerve involvement</li>
          <li><strong>Maintenance and wellness care</strong> — keeping a healthy spine healthy</li>
        </ul>

        <h2>How Many Adjustments Will You Need?</h2>
        <p>This is the question everyone asks, and the honest answer is: it depends. A few factors influence your care plan:</p>
        <ul>
          <li><strong>How long you've had the problem.</strong> Acute conditions that are treated quickly often resolve faster than chronic patterns that have been present for months or years.</li>
          <li><strong>The severity and nature of the dysfunction.</strong> A simple muscle strain responds differently than a herniated disc or degenerative arthritis.</li>
          <li><strong>Your age and overall health.</strong> The body's healing capacity plays a role, though the ProAdjuster is effective across all age groups.</li>
          <li><strong>Your commitment to care.</strong> Consistent appointments in the early phase of care produce faster, more durable results than sporadic visits.</li>
        </ul>
        <p>After your initial assessment, Dr. Yager will give you a clear, honest picture of what your care plan looks like — how many visits, how often, and what milestones to expect. He doesn't keep patients in indefinite care if they're not progressing. And he'll always tell you the truth about what he sees.</p>

        <div class="condition-callout condition-callout--blue">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <div>
            <strong>Most Patients Notice a Difference Fast</strong>
            <p>Many ProHealth patients report feeling noticeably better after their very first adjustment. Results accumulate with each session as normal spinal motion is progressively restored and the surrounding muscles learn to hold the correction.</p>
          </div>
        </div>

        <h2>Is Chiropractic Adjustment Safe?</h2>
        <p>Yes — chiropractic adjustment is one of the safest conservative care options available for spine-related pain. Serious adverse events from chiropractic care are extremely rare. Dr. Yager conducts a thorough health history and assessment before beginning care, and he selects techniques appropriate to each patient's specific situation.</p>
        <p>The ProAdjuster — Dr. Yager's primary tool — is particularly safe because it requires virtually no force and is controlled by computer. It is appropriate even for patients who would be poor candidates for manual manipulation, including those who have had spinal surgery, elderly patients with fragile bone density, pregnant women, and children.</p>

        <h2>Ready to Get Started?</h2>
        <p>New patients at ProHealth Chiropractic receive extra time with Dr. Yager so he can fully understand what's going on and create a care plan that's right for you. Call <strong>(620) 271-0243</strong> or book online to schedule your first visit in Garden City, Kansas.</p>

      </div>

      <!-- SIDEBAR -->
      <aside class="condition-page__sidebar">
        <div class="sidebar-card sidebar-card--primary">
          <h3>Book an Adjustment</h3>
          <p>New patients always get extra time with Dr. Yager. Same-week availability most weeks.</p>
          <a href="https://squareup.com/appointments/book/ejx1i5qse7fkql/LEEFEEKJTRBZY/start" target="_blank" class="btn btn--white btn--block">Book Online</a>
          <a href="tel:6202710243" class="btn btn--outline-white btn--block" style="margin-top:10px;">Call (620) 271-0243</a>
        </div>

        <div class="sidebar-card">
          <h4>Office Hours</h4>
          <ul class="sidebar-hours">
            <li><span>Monday – Thursday</span><span>9am – 5:30pm</span></li>
            <li class="closed"><span>Friday – Sunday</span><span>Closed</span></li>
          </ul>
          <p style="font-size:0.8rem;color:var(--gray);margin-top:8px;">Lunch break 12pm–1pm daily</p>
        </div>

        <div class="sidebar-card">
          <h4>Our Technology</h4>
          <ul class="sidebar-links">
            <li><a href="/services/proadjuster">The ProAdjuster →</a></li>
          </ul>
          <h4 style="margin-top:16px;">Conditions We Treat</h4>
          <ul class="sidebar-links">
            <li><a href="/conditions/back-pain">Back Pain →</a></li>
            <li><a href="/conditions/neck-pain">Neck Pain →</a></li>
            <li><a href="/conditions/sciatica">Sciatica →</a></li>
            <li><a href="/conditions/disc-injury">Disc Injury →</a></li>
            <li><a href="/conditions/auto-accident-injury">Auto Accident →</a></li>
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--review">
          <div class="sidebar-stars">★★★★★</div>
          <p>"Dr. Yager takes time to actually understand what's going on. He doesn't just crack you and send you out the door. The ProAdjuster is unlike anything I've experienced."</p>
          <strong>— ProHealth Patient</strong>
        </div>
      </aside>
    </div>
  </section>

  <CtaBanner
    heading="Find Out Which Adjustment Is Right for You"
    subtext="Dr. Yager will assess your spine and explain exactly what he recommends — and why."
    primaryLabel="Book Your Evaluation"
    secondaryLabel="Call (620) 271-0243"
  />

  <Footer slot="footer" />
</Layout>

<style>
.techniques-grid {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin: 24px 0 32px;
}
.technique-card {
  display: flex;
  gap: 20px;
  padding: 24px;
  background: var(--blue-tint);
  border: 1px solid var(--border);
  border-radius: 12px;
  align-items: flex-start;
}
.technique-card__icon {
  flex-shrink: 0;
  width: 52px;
  height: 52px;
  background: var(--blue-pale);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--blue);
}
.technique-card__body h3 {
  font-size: 1.05rem;
  color: var(--navy);
  margin-bottom: 8px;
}
.technique-card__body p {
  font-size: 0.9rem;
  color: var(--text-body);
  margin-bottom: 8px;
}
.technique-card__best {
  font-size: 0.82rem !important;
  color: var(--text-muted) !important;
  background: var(--blue-pale);
  padding: 6px 10px;
  border-radius: 6px;
}
@media (max-width: 600px) {
  .technique-card { flex-direction: column; }
}
</style>
